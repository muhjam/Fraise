generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  SUPER_ADMIN
}

model User {
  id           String  @id @default(uuid())
  name         String  @default("")
  email        String  @unique
  passwordHash String
  role         Role    @default(USER)
  planId       String?

  // Plan subscription dates
  planStartDate DateTime?
  planEndDate   DateTime?

  // Account verification
  isVerified          Boolean @default(false)
  activationTokenHash String?

  // Password reset fields
  resetTokenHash   String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exams     Exam[]

  @@map("users")
}

model IpTrial {
  id            String   @id @default(uuid())
  ip            String   @unique
  questionsUsed Int      @default(0)
  lastUsedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@map("ip_trials")
}

model Exam {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  language   String
  skills     String[] // e.g. ["Reading", "Writing"]
  provider   String   @default("auto")
  modelName  String?

  status     String   @default("ongoing") // ongoing | completed

  questions  Question[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("exams")
}

model Question {
  id       String @id @default(uuid())
  examId   String
  exam     Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  content  String // the question text / JSON
  type     String // reading | writing | speaking | listening
  answer   String? // user's answer
  score    Float?  // AI-evaluated score

  createdAt DateTime @default(now())

  @@map("questions")
}
